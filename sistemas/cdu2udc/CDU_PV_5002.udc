! Not recognized: variable      X74, Function:      MIN
IQMX     = SEL(   X71,   X73, PQPRI)
X76      = SEL(   X72,   X74, PQPRI)
! Not recognized: variable     IQMN, Function:   FUNCAO
! Not recognized: variable      X78, Function:   FUNCAO
! Not recognized: variable     IPMN, Function:    GANHO
PQPRI    = CONST(#PQPRI)
X501     = COMP6(0, IQ_SP,   1.0,0.0   ,   1.0,   #TG,9999. ,-9999.)
IQX      = LIMIT3(  X501, LIMQX, LIMQN)
LIMQX    = SEL(   INF, IQRMX,    Q0)
LIMQN    = SEL( IQRMN,INFNEG,    Q0)
X018   = MULT(   IQX, VTERM)
! Not recognized: variable     X019, Function:     SOMA
! Not recognized: variable     X020, Function:    GANHO
X021     = LIMIT3(  X020,   INF,  ZERO)
! Not recognized: variable     X022, Function:   COMPAR
X023     = SEL(  ZERO,  X021,  X022)
! Not recognized: variable     X024, Function:     SOMA
X025     = LIMIT3(  X024,   INF, IOLIM)
IQ       = DIVIDE(  X025, VTERM)
VOLIM    = CONST(#VOLIM)
IOLIM    = CONST(#IOLIM)
X509     = COMP6(0, IP_SP,   1.0,0.0   ,   1.0,   #TG, RRPWR,INFNEG)
X015     = LIMIT3(  X509,  LVPL,INFNEG)
X519     = COMP6(0, VTERM,   1.0,0.0   ,   1.0, #TFTR,9999. ,-9999.)
X521     = LFPP2 (  X519,    0.0,   0.01,  0.500,  0.000,  0.900,  1.200,  0.901,  999.0)
LVPL     = LIMIT3(  X521,   INF,  ZERO)
! Not recognized: variable     X016, Function:   FUNCAO
IP     = MULT(  X015,  X016)
INFNEG   = CONST(-9999.)
RRPWR    = CONST( 10.00)
IQRMN    = CONST(  -1.0)
IQRMX    = CONST(   1.0)
! Not recognized: variable   IXFINJ, Function:    GANHO
X1203  = MULT(IXFINJ,SINAVS)
X1205  = MULT(IXFINJ,COSAVS)
! Not recognized: variable   IX_COR, Function:     SOMA
! Not recognized: variable   IY_COR, Function:     SOMA
! Not recognized: variable    X1211, Function:    GANHO
! Not recognized: variable    X1213, Function:    GANHO
X1215    = DIVIDE( X1211, SBASE)
! Not recognized: variable   ITRFNX, Function:    GANHO
! EXPORT(ITRFNT) as IIRFNT
X1221    = DIVIDE( X1213, SBASE)
! Not recognized: variable   ITIFNX, Function:    GANHO
! EXPORT(ITIFNT) as IIIFNT
ITRFNY = MULT(ITRFNX,    UM)
! Not recognized: variable   ITRFNT, Function:    GANHO
