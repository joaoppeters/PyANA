QSPA2    = COMP6(0,  QSPA,  #KQI,0.0   ,   0.0,   1.0,9999. ,-9999.)
! Not recognized: variable    QSPA3, Function:     SOMA
QSPA5    = THOLD( QSPA3,   X34)
QSPA4    = LIMIT3( QSPA5, VMXCL, VMNCL)
! Not recognized: variable    X1892, Function:    GANHO
! Not recognized: variable    X1893, Function:     SOMA
X1894    = LIMIT3( X1893, VMXCL, VMNCL)
! Not recognized: variable    X1531, Function:     SOMA
! Not recognized: variable    X1533, Function:    GANHO
X1532    = COMP6(0, X1531,  #KVI,0.0   ,   0.0,   1.0, XIQMA,XIQMIN)
! Not recognized: variable    X1534, Function:     SOMA
X1558    = THOLD( X1534,   X34)
IQ2      = LIMIT3( X1558,  IQMX,  IQMN)
! Not recognized: variable      IQ3, Function:    GANHO
X1545    = DIVIDE( X0889, VTLIM)
X1546    = COMP6(0, X1545,   1.0,0.0   ,   1.0,  #TIQ,9999. ,-9999.)
! Not recognized: variable    X1547, Function:    GANHO
! Not recognized: variable    X1548, Function:     SOMA
! Not recognized: variable    X1553, Function:     SOMA
X1549    = LIMIT3( X1553,  IQMX,  IQMN)
! Not recognized: variable    IQ_SP, Function:    GANHO
! Not recognized: variable      X31, Function:   COMPAR
! Not recognized: variable      X32, Function:   COMPAR
! Not recognized: variable      X33, Function:    LOGIC
! Not recognized: variable      X34, Function:    LOGIC
X20      = COMP6(0, VTERM,    1.,    0.,    1.,  #TRV,9999. ,-9999.)
! Not recognized: variable      X21, Function:     SOMA
X22      = DDBND4 (   X21,  #DBD1,     1.,     1.,  #DBD2)
X23    = MULT(   X21,   X22)
! Not recognized: variable      X24, Function:    GANHO
X25      = LIMIT3(   X24,  IQH1,  IQL1)
IQINJ  = MULT(   X25,   X31)
QMIN     = CONST(-0.436)
QMAX     = CONST( 0.296)
VMNCL    = CONST(   0.8)
VMXCL    = CONST(   1.2)
VREF1    = CONST(  ZERO)
VTLIM    = LIMIT3(    VS,   INF, VTMIN)
VTMIN    = CONST( 0.050)
XIQMIN   = CONST(  -0.5)
VUP      = CONST(  #VUP)
IQL1     = CONST( #IQL1)
IQH1     = CONST( #IQH1)
PREF     = CONST( P1GPU)
! Not recognized: variable    X0001, Function:     SOMA
X0002    = LIMIT3( X0001, RPMAX, RPMIN)
! Not recognized: variable    X0003, Function:     SOMA
! Not recognized: variable    X0337, Function:    DELAY
RPMAX  = MULT(    DT,RPMAXX)
RPMIN  = MULT(    DT,RPMINX)
PSP1     = COMP6(0, X0003,   1.0,0.0   ,   1.0,#TPORD,   PMX,   PMN)
PSP      = THOLD(  PSP1,   X34)
X1519    = DIVIDE(   PSP, VTLIM)
IP1      = LIMIT3( X1519,  IPMX,  IPMN)
! Not recognized: variable    IP_SP, Function:    GANHO
RPMINX   = CONST( -0.45)
RPMAXX   = CONST(  0.45)
PMN      = CONST(  0.04)
PMX      = CONST(  1.10)
X62      = LFPP2 (VT_FIL,   #VQ1,   #IQ1,   #VQ2,   #IQ2,   #VQ3,   #IQ3,   #VQ4,   #IQ4)
X63      = LFPP2 (VT_FIL,   #VP1,   #IP1,   #VP2,   #IP2,   #VP3,   #IP3,   #VP4,   #IP4)
