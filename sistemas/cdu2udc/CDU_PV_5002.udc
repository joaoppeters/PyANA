QEXT1    = COMP6(0, QSPX2,   1.0,  #TFT,   1.0,  #TFV,9999. ,-9999.)
! Not recognized: variable     QEXT, Function:    GANHO
! Not recognized: variable     X310, Function:   COMPAR
! Not recognized: variable     X330, Function:    LOGIC
! Not recognized: variable     X340, Function:    LOGIC
VFRZ     = CONST(#VFRZ )
PREFF    = LIMIT3(    P0,   INF, ZPZZ1)
TANFI    = DIVIDE(  QREF, PREFF)
PELEC1   = COMP6(0,    P0,   1.0,0.0   ,   1.0, #TP_1,9999. ,-9999.)
X0854  = MULT( TANFI,PELEC1)
! Not recognized: variable      OP3, Function:    GANHO
! Not recognized: variable    X0889, Function:     SOMA
! Not recognized: variable    X1890, Function:     SOMA
! Not recognized: variable    X1891, Function:    GANHO
