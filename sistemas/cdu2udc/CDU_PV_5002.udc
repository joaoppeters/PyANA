!
! Not recognized: variable         , Function:   2 PV  
PGENPU   = INPXXX() !IMPORT
PGENMW = MULT(PGENPU, SBASE)
P1GW     = FRAC(PGENMW,  1.E6, #NMAQ)
P1GPU    = FRAC(  P1GW, 1.E-6,#MBASE)
QGENPU   = INPXXX() !IMPORT
QGENMA = MULT(QGENPU, SBASE)
Q1GVAR   = FRAC(QGENMA,  1.E6, #NMAQ)
Q1GPU    = FRAC(Q1GVAR, 1.E-6,#MBASE)
! Not recognized: variable    QELEC, Function:    GANHO
VS       = INPXXX() !IMPORT
! Not recognized: variable    VTERM, Function:    GANHO
AVS      = INPXXX() !IMPORT
SBASE    = INPXXX() !IMPORT
DT       = INPXXX() !IMPORT
UM       = CONST(   1.0)
ZERO     = CONST(   0.0)
INF      = CONST( 9999.)
! Not recognized: variable   COSAVS, Function:   FUNCAO
! Not recognized: variable   SINAVS, Function:   FUNCAO
P0       = CONST( P1GPU)
Q0       = CONST( Q1GPU)
V0       = CONST( VTERM)
VT_FIL   = COMP6(0, VTERM,   1.0,0.0   ,   1.0,#TFLTR,9999. ,-9999.)
VSP      = CONST(VT_FIL)
! Not recognized: variable    X0607, Function:     SOMA
! Not recognized: variable     QREF, Function:    GANHO
QELEC1   = COMP6(0, QELEC,   1.0,0.0   ,   1.0,#TFLTR,9999. ,-9999.)
